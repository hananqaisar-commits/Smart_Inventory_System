<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="Infinity" maxWidth="Infinity" minHeight="0" minWidth="0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.NexStock.controller.createAccount">

    <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <StackPane>
            <StackPane maxHeight="Infinity" maxWidth="430" minWidth="430" style="-fx-background-image: url('com/NexStock/images/2.png');                               -fx-background-size: cover;                               -fx-background-position: center;" HBox.hgrow="NEVER" />
        </StackPane>
        <VBox alignment="CENTER" maxHeight="Infinity" maxWidth="Infinity" prefHeight="807.0" prefWidth="913.0" style="-fx-background-color: #0B0F19;" HBox.hgrow="ALWAYS">
            <StackPane maxWidth="350">
                <VBox.margin>
                    <Insets right="120.0" top="30.0" />
                </VBox.margin>
                <AnchorPane prefHeight="44.0" prefWidth="350.0">
                    <ImageView fitHeight="30.0" fitWidth="30.0" layoutX="10.0" layoutY="7.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../images/user.png" />
                        </image>
                    </ImageView>
                    <TextField fx:id="fullname" prefHeight="44.0" prefWidth="350.0" promptText="   Full Name" style="-fx-border-radius: 22;                                       -fx-background-radius: 22;                                       -fx-background-color: white;                                       -fx-padding: 0 10 0 45;">
                        <font>
                            <Font size="17.0" />
                        </font>
                    </TextField>
                    <ImageView fitHeight="30.0" fitWidth="30.0" layoutX="10.0" layoutY="7.0" mouseTransparent="true" pickOnBounds="false" preserveRatio="true">
                        <image>
                            <Image url="@../images/user.png" />
                        </image>
                    </ImageView>
                </AnchorPane>
            </StackPane>
            <StackPane maxWidth="350">
                <VBox.margin>
                    <Insets right="80.0" top="18.0" />
                </VBox.margin>
                <AnchorPane prefHeight="44.0" prefWidth="350.0">
                    <TextField fx:id="username" layoutX="0.0" layoutY="0.0" prefHeight="44.0" prefWidth="350.0" promptText="   Username" style="-fx-border-radius: 22;                                       -fx-background-radius: 22;                                       -fx-background-color: white;                                       -fx-padding: 0 10 0 45;">
                        <font>
                            <Font size="17.0" />
                        </font>
                    </TextField>
                    <ImageView fitHeight="28.0" fitWidth="28.0" layoutX="10.0" layoutY="8.0" mouseTransparent="true" pickOnBounds="false" preserveRatio="true">
                        <image>
                            <Image url="@../images/at-sign.png" />
                        </image>
                    </ImageView>
                </AnchorPane>
            </StackPane>
            <StackPane maxWidth="350">
                <VBox.margin>
                    <Insets right="40.0" top="18.0" />
                </VBox.margin>
                <AnchorPane prefHeight="44.0" prefWidth="350.0">
                    <PasswordField fx:id="passwordbutton" layoutX="0.0" layoutY="0.0" prefHeight="44.0" prefWidth="350.0" promptText="   Password" style="-fx-background-radius: 22;                                          -fx-border-radius: 22;                                          -fx-background-color: white;                                          -fx-padding: 0 10 0 45;">
                        <font>
                            <Font size="17.0" />
                        </font>
                    </PasswordField>
                    <ImageView fitHeight="28.0" fitWidth="28.0" layoutX="10.0" layoutY="8.0" mouseTransparent="true" pickOnBounds="false" preserveRatio="true">
                        <image>
                            <Image url="@../images/hide.png" />
                        </image>
                    </ImageView>
                </AnchorPane>
            </StackPane>
            <StackPane maxWidth="350">
                <VBox.margin>
                    <Insets top="20.0" />
                </VBox.margin>
                <AnchorPane prefHeight="44.0" prefWidth="350.0">
                    <PasswordField fx:id="confirmpasswordbutton" layoutX="0.0" layoutY="0.0" prefHeight="44.0" prefWidth="350.0" promptText="   Confirm Password" style="-fx-background-radius: 22;                                          -fx-border-radius: 22;                                          -fx-background-color: white;                                          -fx-padding: 0 10 0 45;">
                        <font>
                            <Font size="17.0" />
                        </font>
                    </PasswordField>
                    <ImageView fitHeight="28.0" fitWidth="28.0" layoutX="10.0" layoutY="8.0" mouseTransparent="true" pickOnBounds="false" preserveRatio="true">
                        <image>
                            <Image url="@../images/hide.png" />
                        </image>
                    </ImageView>
                </AnchorPane>
            </StackPane>

            <StackPane maxWidth="350">
                <VBox.margin>
                    <Insets left="40.0" top="18.0" />
                </VBox.margin>
                <AnchorPane prefHeight="44.0" prefWidth="350.0">
                    <TextField fx:id="email" layoutX="0.0" layoutY="0.0" prefHeight="44.0" prefWidth="350.0" promptText="   E-mail" style="-fx-border-radius: 22;                                       -fx-background-radius: 22;                                       -fx-background-color: white;                                       -fx-padding: 0 10 0 45;">
                        <font>
                            <Font size="17.0" />
                        </font>
                    </TextField>
                    <ImageView fitHeight="28.0" fitWidth="28.0" layoutX="10.0" layoutY="8.0" mouseTransparent="true" pickOnBounds="false" preserveRatio="true">
                        <image>
                            <Image url="@../images/mail.png" />
                        </image>
                    </ImageView>
                </AnchorPane>
            </StackPane>

            <CheckBox fx:id="checkboxtick" mnemonicParsing="false" text="Admin" textFill="WHITE">
                <VBox.margin>
                    <Insets top="20.0" />
                </VBox.margin>
                <font>
                    <Font size="16.0" />
                </font>
            </CheckBox>
            <Button fx:id="createaccountbutton" mnemonicParsing="false" onAction="#createaccount" prefHeight="44.0" prefWidth="200.0" style="-fx-background-radius: 22;                            -fx-border-color: #0D47A1;                            -fx-background-color: #121826;                            -fx-border-radius: 22;                            -fx-cursor: hand;" text="Create Account" textFill="WHITE">
                <VBox.margin>
                    <Insets top="25.0" />
                </VBox.margin>
                <font>
                    <Font size="16.0" />
                </font>
            </Button>
            <Label fx:id="labelshow" alignment="CENTER" prefHeight="30.0" prefWidth="350.0" textFill="WHITE">
                <VBox.margin>
                    <Insets top="15.0" />
                </VBox.margin>
                <font>
                    <Font size="15.0" />
                </font>
            </Label>

        </VBox>
    </HBox>
</AnchorPane>
